<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background photo (day / night, swapped on weather load) -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/day_image"
        android:contentDescription="@null" />

    <!-- Semi-transparent overlay — colour resolved per light/dark system mode -->
    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorWeatherOverlay" />

    <!-- Main content — top/bottom padding is set in code to account for system bars -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="@dimen/content_padding_top"
        android:paddingBottom="@dimen/content_padding_bottom"
        android:paddingHorizontal="@dimen/content_padding_horizontal">

        <!-- ── Search row ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/buttonLocation"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_location"
                android:padding="8dp"
                android:background="@drawable/bg_weather_card"
                android:contentDescription="@null"
                app:tint="@color/colorWeatherText" />

            <EditText
                android:id="@+id/editCity"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="10dp"
                android:hint="@string/search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/colorWeatherText"
                android:textColorHint="@color/colorWeatherHint"
                android:textColorHighlight="#33FFFFFF"
                android:background="@drawable/bg_search"
                android:paddingHorizontal="14dp" />

            <ImageView
                android:id="@+id/buttonSearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_search"
                android:padding="8dp"
                android:background="@drawable/bg_weather_card"
                android:contentDescription="@null"
                app:tint="@color/colorWeatherText" />

        </LinearLayout>

        <!-- ── Spacer ────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- ── Weather icon ──────────────────────────────────────────── -->
        <ImageView
            android:id="@+id/imageCondition"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:contentDescription="@null"
            app:tint="@color/colorWeatherText" />

        <!-- ── Temperature ───────────────────────────────────────────── -->
        <TextView
            android:id="@+id/textTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textSize="80sp"
            android:textStyle="bold"
            android:textColor="@color/colorWeatherText"
            android:letterSpacing="-0.03"
            android:visibility="gone" />

        <!-- ── Condition text (e.g. "Partly cloudy") ─────────────────── -->
        <TextView
            android:id="@+id/textCondition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:textSize="18sp"
            android:textColor="@color/colorWeatherTextSecondary"
            android:visibility="gone" />

        <!-- ── City name ─────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/textCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/colorWeatherText"
            android:visibility="gone" />

        <!-- ── Region, Country ───────────────────────────────────────── -->
        <TextView
            android:id="@+id/textRegion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:textSize="14sp"
            android:textColor="@color/colorWeatherTextSecondary"
            android:visibility="gone" />

        <!-- ── Flexible spacer pushes detail card to the bottom ──────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ── Detail card (humidity + feels like) ───────────────────── -->
        <LinearLayout
            android:id="@+id/detailCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_weather_card"
            android:paddingVertical="20dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <!-- Humidity column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/textHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorWeatherText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Humidity"
                    android:textSize="12sp"
                    android:textColor="@color/colorWeatherTextSecondary" />

            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="48dp"
                android:background="@color/colorDetailDivider" />

            <!-- Feels like column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌡️"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/textFeelsLike"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorWeatherText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feels like"
                    android:textSize="12sp"
                    android:textColor="@color/colorWeatherTextSecondary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Full-screen loading overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/colorWeatherText" />

    </FrameLayout>

</FrameLayout>
